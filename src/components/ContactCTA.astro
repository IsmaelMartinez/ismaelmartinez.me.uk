---
import { useTranslations, getLocalizedPath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';
import { socialLinks } from '../data/links';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const linkedInUrl = socialLinks.find(link => link.name === 'LinkedIn')?.url ?? 'https://www.linkedin.com/in/ismaelmartinezramos';
---

<section class="section cta-section">
  <div class="container">
    <div class="cta-panel">
      <h2 class="cta-title">{t('cta.title')}</h2>
      <p class="cta-description">{t('cta.description')}</p>
      <div class="cta-actions">
        <a href={getLocalizedPath('/connect', lang)} class="btn btn-primary">{t('cta.connect')} →</a>
        <a
          href={linkedInUrl}
          class="btn btn-outline"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t('cta.linkedin')}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-top: 0;
  }

  .cta-panel {
    text-align: center;
    padding: var(--space-2xl) var(--space-xl);
    background: var(--color-accent-solid);
    color: #fff;
    border: var(--frame-width) solid var(--color-frame);
    border-radius: var(--radius);
    box-shadow: var(--shadow-card);
  }

  .cta-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    margin-bottom: var(--space-md);
  }

  .cta-description {
    font-family: var(--font-serif);
    font-style: italic;
    color: rgba(255, 255, 255, 0.88);
    max-width: 540px;
    margin: 0 auto var(--space-xl);
    line-height: 1.7;
    font-size: 1.1rem;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-panel .btn-primary {
    background: var(--color-bg);
    color: var(--color-text);
  }

  .cta-panel .btn-primary:hover {
    background: var(--color-bg-secondary);
    color: var(--color-accent);
  }

  .cta-panel .btn-outline {
    background: transparent;
    color: #fff;
  }

  .cta-panel .btn-outline:hover {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
  }
</style>
