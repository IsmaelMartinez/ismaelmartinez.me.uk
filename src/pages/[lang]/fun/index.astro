---
import Layout from '../../../layouts/Layout.astro';
import ArcadeCabinet from '../../../components/ArcadeCabinet.astro';
import { useTranslations, getLocalizedPath, locales } from '../../../i18n/translations';
import type { Locale, TranslationKey } from '../../../i18n/translations';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

interface ArcadeGame {
  id: string;
  title: string;
  taglineKey: TranslationKey;
  genreKey: TranslationKey;
  twoPlayer: boolean;
  icon: string;
  color: string;
  path: string;
  isNew?: boolean;
}

const arcadeGames: ArcadeGame[] = [
  {
    id: 'snake',
    title: 'SNAKE',
    taglineKey: 'fun.snake.description',
    genreKey: 'fun.arcade.genre.snake',
    twoPlayer: false,
    icon: '🐍',
    color: '#14b8a6',
    path: '/fun/snake'
  },
  {
    id: 'poo-poo-land',
    title: 'POO POO LAND',
    taglineKey: 'fun.pooLand.description',
    genreKey: 'fun.arcade.genre.pooLand',
    twoPlayer: false,
    icon: '🔍💩',
    color: '#0ea5e9',
    path: '/fun/poo-poo-land'
  },
  {
    id: 'tanks',
    title: 'TANK DUEL',
    taglineKey: 'fun.tanks.description',
    genreKey: 'fun.arcade.genre.tanks',
    twoPlayer: true,
    icon: '🎯',
    color: '#3b82f6',
    path: '/fun/tanks'
  },
  {
    id: 'park',
    title: 'PIXEL PARK',
    taglineKey: 'fun.park.description',
    genreKey: 'fun.arcade.genre.park',
    twoPlayer: false,
    icon: '🎢',
    color: '#818cf8',
    path: '/fun/park'
  },
  {
    id: 'city',
    title: 'MICROCITY',
    taglineKey: 'fun.city.description',
    genreKey: 'fun.arcade.genre.city',
    twoPlayer: false,
    icon: '🏙️',
    color: '#38bdf8',
    path: '/fun/city'
  },
  {
    id: 'syndicate',
    title: 'SYNDICATE',
    taglineKey: 'fun.syndicate.description',
    genreKey: 'fun.arcade.genre.syndicate',
    twoPlayer: false,
    icon: '🕶️',
    color: '#22d3ee',
    path: '/fun/syndicate'
  },
  {
    id: 'lemmings',
    title: 'CRITTER RESCUE',
    taglineKey: 'fun.lemmings.description',
    genreKey: 'fun.arcade.genre.lemmings',
    twoPlayer: false,
    icon: '🐛',
    color: '#84cc16',
    path: '/fun/lemmings',
    isNew: true
  }
];
---

<Layout title="The Arcade" lang={lang}>
  <div class="arcade-room">
    <div class="neon-grid"></div>

    <div class="arcade-header">
      <div class="neon-sign">
        <span class="neon-text">ISMAEL'S</span>
        <span class="neon-text accent">ARCADE</span>
      </div>
      <p class="arcade-subtitle">{t('fun.arcade.subtitle')}</p>
    </div>

    <div class="arcade-floor">
      <div class="cabinets-row">
        {arcadeGames.map(game => (
          <ArcadeCabinet
            id={game.id}
            title={game.title}
            tagline={t(game.taglineKey)}
            genre={t(game.genreKey)}
            players={game.twoPlayer ? t('fun.arcade.twoPlayers') : t('fun.arcade.onePlayer')}
            icon={game.icon}
            color={game.color}
            href={getLocalizedPath(game.path, lang)}
            bestLabel={t('fun.arcade.best')}
            newBadge={game.isNew ? t('fun.arcade.new') : undefined}
          />
        ))}
      </div>
    </div>

    <div class="arcade-decorations">
      <div class="floor-reflection"></div>
    </div>

    <div class="arcade-tip">
      <p>{t('fun.arcade.konamiTip')}</p>
    </div>
  </div>
</Layout>

<script>
  // Fill each cabinet's attract screen with the top of the game's high-score
  // table, initials and all (loading a table migrates the game's pre-table
  // best automatically). Re-runs after ClientRouter swaps so scores earned
  // in a game show up when navigating back to the arcade.
  import { topEntry, formatScore } from '../../../games/engine/highscores';

  function showBestScores() {
    const readouts = document.querySelectorAll<HTMLElement>('.best-value[data-game-id]');
    for (const readout of readouts) {
      const top = readout.dataset.gameId ? topEntry(readout.dataset.gameId) : null;
      readout.textContent = top
        ? `${top.initials} ${formatScore(top.score)}`
        : formatScore(0);
    }
  }

  showBestScores();
  document.addEventListener('astro:after-swap', showBestScores);
</script>

<style>
  /* The room follows the site theme: a bright showroom on the light "paper &
     ink" palette, the neon-dark arcade after dark. Only the room shell reacts —
     the cabinets are dark physical objects in both. */
  .arcade-room {
    --room-bg: linear-gradient(180deg, #eaf0f9 0%, #dde7f7 55%, #cfdcf0 100%);
    --room-grid: rgba(29, 78, 216, 0.08);
    --sign-main: var(--color-text);
    --sign-main-glow:
      0 0 1px rgba(29, 78, 216, 0.5),
      0 0 14px rgba(37, 99, 235, 0.35),
      0 0 34px rgba(37, 99, 235, 0.2);
    --sign-accent: var(--color-accent-solid);
    --sign-accent-glow:
      0 0 1px rgba(29, 78, 216, 0.5),
      0 0 14px rgba(0, 183, 255, 0.45),
      0 0 34px rgba(0, 183, 255, 0.25);

    min-height: calc(100vh - var(--nav-height));
    background: var(--room-bg);
    position: relative;
    overflow: hidden;
    padding: var(--space-2xl) var(--space-lg);
  }

  :global(:root[data-theme='dark']) .arcade-room {
    --room-bg: linear-gradient(180deg, #0a0a12 0%, #1a1a2e 50%, #16213e 100%);
    --room-grid: rgba(59, 130, 246, 0.04);
    --sign-main: #fff;
    --sign-main-glow: 0 0 5px #fff, 0 0 10px #fff, 0 0 20px #2563eb, 0 0 40px #2563eb, 0 0 80px #2563eb;
    --sign-accent: #0ff;
    --sign-accent-glow: 0 0 5px #0ff, 0 0 10px #0ff, 0 0 20px #0ff, 0 0 40px #00b7ff, 0 0 80px #00b7ff;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .arcade-room {
      --room-bg: linear-gradient(180deg, #0a0a12 0%, #1a1a2e 50%, #16213e 100%);
      --room-grid: rgba(59, 130, 246, 0.04);
      --sign-main: #fff;
      --sign-main-glow: 0 0 5px #fff, 0 0 10px #fff, 0 0 20px #2563eb, 0 0 40px #2563eb, 0 0 80px #2563eb;
      --sign-accent: #0ff;
      --sign-accent-glow: 0 0 5px #0ff, 0 0 10px #0ff, 0 0 20px #0ff, 0 0 40px #00b7ff, 0 0 80px #00b7ff;
    }
  }

  .neon-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      linear-gradient(var(--room-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--room-grid) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
  }

  .arcade-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    position: relative;
    z-index: 10;
  }

  .neon-sign {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .neon-text {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 8vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--sign-main);
    text-shadow: var(--sign-main-glow);
    animation: neonFlicker 3s ease-in-out infinite;
  }

  .neon-text.accent {
    color: var(--sign-accent);
    text-shadow: var(--sign-accent-glow);
    animation: neonFlicker 2.5s ease-in-out infinite reverse;
  }

  @keyframes neonFlicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
      opacity: 1;
    }
    20%, 24%, 55% {
      opacity: 0.8;
    }
  }

  .arcade-subtitle {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    animation: blink 1.5s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0.5; }
  }

  .arcade-floor {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* flex-wrap centres partial rows, so an orphan pair of cabinets doesn't
     hang off the left edge the way a grid row would. */
  .cabinets-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: stretch;
    gap: var(--space-2xl) var(--space-xl);
    padding: var(--space-xl) 0;
  }

  .arcade-decorations {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 150px;
    pointer-events: none;
  }

  .floor-reflection {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: linear-gradient(180deg, transparent 0%, rgba(59, 130, 246, 0.06) 100%);
  }

  .arcade-tip {
    text-align: center;
    margin-top: var(--space-3xl);
    position: relative;
    z-index: 10;
  }

  .arcade-tip p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .arcade-room {
      padding: var(--space-xl) var(--space-md);
    }

    .cabinets-row {
      gap: var(--space-xl) var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .neon-text {
      letter-spacing: 0.1em;
    }

    .cabinets-row {
      gap: var(--space-lg) var(--space-md);
    }
  }
</style>
