---
import Layout from '../../../layouts/Layout.astro';
import ArcadeCabinet from '../../../components/ArcadeCabinet.astro';
import { useTranslations, getLocalizedPath, locales } from '../../../i18n/translations';
import type { Locale, TranslationKey } from '../../../i18n/translations';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

interface ArcadeGame {
  id: string;
  title: string;
  taglineKey: TranslationKey;
  genreKey: TranslationKey;
  twoPlayer: boolean;
  icon: string;
  color: string;
  path: string;
  scoreKey: string;
  isNew?: boolean;
}

const arcadeGames: ArcadeGame[] = [
  {
    id: 'snake',
    title: 'SNAKE',
    taglineKey: 'fun.snake.description',
    genreKey: 'fun.arcade.genre.snake',
    twoPlayer: false,
    icon: '🐍',
    color: '#14b8a6',
    path: '/fun/snake',
    scoreKey: 'snake-high-score'
  },
  {
    id: 'poo-poo-land',
    title: 'POO POO LAND',
    taglineKey: 'fun.pooLand.description',
    genreKey: 'fun.arcade.genre.pooLand',
    twoPlayer: false,
    icon: '🔍💩',
    color: '#0ea5e9',
    path: '/fun/poo-poo-land',
    scoreKey: 'poo-land-high-score'
  },
  {
    id: 'tanks',
    title: 'TANK DUEL',
    taglineKey: 'fun.tanks.description',
    genreKey: 'fun.arcade.genre.tanks',
    twoPlayer: true,
    icon: '🎯',
    color: '#3b82f6',
    path: '/fun/tanks',
    scoreKey: 'tanks-victories'
  },
  {
    id: 'park',
    title: 'PIXEL PARK',
    taglineKey: 'fun.park.description',
    genreKey: 'fun.arcade.genre.park',
    twoPlayer: false,
    icon: '🎢',
    color: '#818cf8',
    path: '/fun/park',
    scoreKey: 'park-record-guests'
  },
  {
    id: 'city',
    title: 'MICROCITY',
    taglineKey: 'fun.city.description',
    genreKey: 'fun.arcade.genre.city',
    twoPlayer: false,
    icon: '🏙️',
    color: '#38bdf8',
    path: '/fun/city',
    scoreKey: 'city-record-pop'
  },
  {
    id: 'syndicate',
    title: 'SYNDICATE',
    taglineKey: 'fun.syndicate.description',
    genreKey: 'fun.arcade.genre.syndicate',
    twoPlayer: false,
    icon: '🕶️',
    color: '#22d3ee',
    path: '/fun/syndicate',
    scoreKey: 'syndicate-record-cash',
    isNew: true
  }
];
---

<Layout title="The Arcade" lang={lang}>
  <div class="arcade-room">
    <div class="neon-grid"></div>

    <div class="arcade-header">
      <div class="neon-sign">
        <span class="neon-text">ISMAEL'S</span>
        <span class="neon-text accent">ARCADE</span>
      </div>
      <p class="arcade-subtitle">{t('fun.arcade.subtitle')}</p>
    </div>

    <div class="arcade-floor">
      <div class="cabinets-grid">
        {arcadeGames.map(game => (
          <ArcadeCabinet
            id={game.id}
            title={game.title}
            tagline={t(game.taglineKey)}
            genre={t(game.genreKey)}
            players={game.twoPlayer ? t('fun.arcade.twoPlayers') : t('fun.arcade.onePlayer')}
            icon={game.icon}
            color={game.color}
            href={getLocalizedPath(game.path, lang)}
            scoreKey={game.scoreKey}
            bestLabel={t('fun.arcade.best')}
            newBadge={game.isNew ? t('fun.arcade.new') : undefined}
          />
        ))}
      </div>
    </div>

    <div class="arcade-decorations">
      <div class="floor-reflection"></div>
    </div>

    <div class="arcade-tip">
      <p>{t('fun.arcade.konamiTip')}</p>
    </div>
  </div>
</Layout>

<script>
  // Fill each cabinet's attract screen with the player's saved best score,
  // padded like an arcade high-score table. Re-runs after ClientRouter swaps
  // so scores earned in a game show up when navigating back to the arcade.
  import { loadScore } from '../../../games/engine/storage';

  function showBestScores() {
    const readouts = document.querySelectorAll<HTMLElement>('.best-value[data-score-key]');
    for (const readout of readouts) {
      const key = readout.dataset.scoreKey;
      if (key) readout.textContent = loadScore(key).toString().padStart(6, '0');
    }
  }

  showBestScores();
  document.addEventListener('astro:after-swap', showBestScores);
</script>

<style>
  .arcade-room {
    min-height: calc(100vh - var(--nav-height));
    background: linear-gradient(180deg, #0a0a12 0%, #1a1a2e 50%, #16213e 100%);
    position: relative;
    overflow: hidden;
    padding: var(--space-2xl) var(--space-lg);
  }

  .neon-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      linear-gradient(rgba(59, 130, 246, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59, 130, 246, 0.04) 1px, transparent 1px);
    background-size: 50px 50px;
    animation: gridMove 20s linear infinite;
  }

  @keyframes gridMove {
    0% { background-position: 0 0; }
    100% { background-position: 50px 50px; }
  }

  .arcade-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
    position: relative;
    z-index: 10;
  }

  .neon-sign {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
  }

  .neon-text {
    font-family: var(--font-mono);
    font-size: clamp(2rem, 8vw, 4rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #fff;
    text-shadow:
      0 0 5px #fff,
      0 0 10px #fff,
      0 0 20px #2563eb,
      0 0 40px #2563eb,
      0 0 80px #2563eb;
    animation: neonFlicker 3s ease-in-out infinite;
  }

  .neon-text.accent {
    color: #0ff;
    text-shadow:
      0 0 5px #0ff,
      0 0 10px #0ff,
      0 0 20px #0ff,
      0 0 40px #00b7ff,
      0 0 80px #00b7ff;
    animation: neonFlicker 2.5s ease-in-out infinite reverse;
  }

  @keyframes neonFlicker {
    0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% {
      opacity: 1;
    }
    20%, 24%, 55% {
      opacity: 0.8;
    }
  }

  .arcade-subtitle {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    animation: blink 1.5s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0.5; }
  }

  .arcade-floor {
    position: relative;
    z-index: 10;
    max-width: 1100px;
    margin: 0 auto;
  }

  .cabinets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    justify-items: center;
    align-items: stretch;
    gap: var(--space-2xl) var(--space-xl);
    padding: var(--space-xl) 0;
  }

  .arcade-decorations {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 150px;
    pointer-events: none;
  }

  .floor-reflection {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: linear-gradient(180deg, transparent 0%, rgba(59, 130, 246, 0.06) 100%);
  }

  .arcade-tip {
    text-align: center;
    margin-top: var(--space-3xl);
    position: relative;
    z-index: 10;
  }

  .arcade-tip p {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .arcade-room {
      padding: var(--space-xl) var(--space-md);
    }

    .cabinets-grid {
      gap: var(--space-xl) var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    .neon-text {
      letter-spacing: 0.1em;
    }

    .cabinets-grid {
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: var(--space-lg) var(--space-md);
    }
  }
</style>
