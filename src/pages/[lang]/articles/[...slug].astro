---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../../layouts/ArticleLayout.astro';
import { getReadingTime } from '../../../utils/reading-time';
import { locales } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  return locales.flatMap(lang =>
    articles
      .filter(({ id, data }) => id.startsWith(`${lang}/`) && (import.meta.env.DEV || import.meta.env.VERCEL_ENV === 'preview' || !data.draft))
      .map(article => ({
        params: { lang, slug: article.id.replace(`${lang}/`, '') },
        props: { article },
      }))
  );
}

const lang = Astro.params.lang as Locale;
const { article } = Astro.props;
const { Content } = await render(article);
const readingTime = getReadingTime(article.body || '');
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  publishedDate={article.data.publishedDate}
  updatedDate={article.data.updatedDate}
  originalUrl={article.data.originalUrl}
  originalPlatform={article.data.originalPlatform}
  heroImage={article.data.heroImage}
  tags={article.data.tags}
  lang={lang}
  slug={article.id}
  readingTime={readingTime}
>
  <Content />
</ArticleLayout>
