---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations, getLocalizedPath, locales } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const tools = [
  { id: 'road', emoji: '🛣️', label: t('fun.city.toolRoad'), cost: 10 },
  { id: 'res', emoji: '🏠', label: t('fun.city.toolRes'), cost: 50 },
  { id: 'com', emoji: '🏬', label: t('fun.city.toolCom'), cost: 75 },
  { id: 'ind', emoji: '🏭', label: t('fun.city.toolInd'), cost: 100 },
  { id: 'power', emoji: '⚡', label: t('fun.city.toolPower'), cost: 500 },
  { id: 'park', emoji: '🌳', label: t('fun.city.toolPark'), cost: 30 },
  { id: 'school', emoji: '🏫', label: t('fun.city.toolSchool'), cost: 300 },
  { id: 'firehouse', emoji: '🚒', label: t('fun.city.toolFirehouse'), cost: 250 },
  { id: 'bulldoze', emoji: '🚜', label: t('fun.city.toolBulldoze'), cost: 0 }
];
---

<Layout title="Microcity" lang={lang}>
  <section class="city-section">
    <div class="container">
      <a href={getLocalizedPath('/fun', lang)} class="back-link">← {t('fun.backToFun')}</a>

      <div
        class="game-container"
        id="city-root"
        data-t-month={t('fun.city.month')}
        data-t-income={t('fun.city.income')}
        data-t-expenses={t('fun.city.expenses')}
        data-t-cant-afford={t('fun.city.cantAfford')}
        data-t-milestone={t('fun.city.milestone')}
        data-t-fire-alert={t('fun.city.fireAlert')}
        data-t-event-grant={t('fun.city.eventGrant')}
        data-t-event-protest={t('fun.city.eventProtest')}
        data-t-event-festival={t('fun.city.eventFestival')}
        data-t-event-strike={t('fun.city.eventStrike')}
        data-t-event-boom={t('fun.city.eventBoom')}
      >
        <div class="game-header">
          <h1><span class="city-emoji">🏙️</span> {t('fun.city.title')}</h1>
          <button
            id="sound-btn"
            class="btn sound-btn"
            aria-label={t('fun.arcade.soundOn')}
            data-sound-on={t('fun.arcade.soundOn')}
            data-sound-off={t('fun.arcade.soundOff')}
          >🔊</button>
          <div class="scores">
            <div class="score-item">
              <span class="score-label">{t('fun.city.money')}</span>
              <span id="money" class="score-value money">£2500</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.city.population')}</span>
              <span id="population" class="score-value">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.city.jobs')}</span>
              <span id="jobs" class="score-value">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.city.month')}</span>
              <span id="month" class="score-value">1</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.city.record')}</span>
              <span id="record" class="score-value">0</span>
            </div>
          </div>
        </div>

        <div class="game-area">
          <div class="canvas-scroll" id="canvas-scroll">
            <canvas id="game-canvas"></canvas>
          </div>
          <div id="toast-area" class="toast-area"></div>
          <div id="start-overlay" class="game-overlay">
            <div class="overlay-content">
              <span class="play-icon">🏙️</span>
              <p>{t('fun.city.instructions')}</p>
              <button id="start-btn" class="btn btn-primary btn-large">{t('fun.city.start')}</button>
            </div>
          </div>
          <div id="over-overlay" class="game-overlay" style="display: none;">
            <div class="overlay-content">
              <span class="play-icon">💸</span>
              <h2>{t('fun.city.gameOver')}</h2>
              <p>{t('fun.city.gameOverDesc')}</p>
              <p class="final-stats">
                {t('fun.city.monthsLabel')}: <strong id="final-months">0</strong> ·
                {t('fun.city.peakPop')}: <strong id="final-pop">0</strong>
              </p>
              <button id="restart-btn" class="btn btn-primary btn-large">{t('fun.city.playAgain')}</button>
            </div>
          </div>
        </div>

        <div class="controls">
          <div class="toolbar">
            {tools.map((tool, i) => (
              <button class={`tool-btn${i === 0 ? ' active' : ''}`} data-tool={tool.id}>
                <span class="tool-emoji">{tool.emoji}</span>
                <span class="tool-label">{tool.label}</span>
                <span class="tool-cost">{tool.cost > 0 ? `£${tool.cost}` : '—'}</span>
              </button>
            ))}
          </div>
          <div class="side-controls">
            <div class="demand-meter" title={t('fun.city.demand')}>
              <div class="demand-col">
                <div class="demand-track"><div id="demand-res" class="demand-fill res"></div></div>
                <span class="demand-label">R</span>
              </div>
              <div class="demand-col">
                <div class="demand-track"><div id="demand-com" class="demand-fill com"></div></div>
                <span class="demand-label">C</span>
              </div>
              <div class="demand-col">
                <div class="demand-track"><div id="demand-ind" class="demand-fill ind"></div></div>
                <span class="demand-label">I</span>
              </div>
            </div>
            <div class="speed-controls">
              <button type="button" id="rotate-left" class="rotate-btn" aria-label={t('fun.city.rotateLeft')} title={t('fun.city.rotateLeft')}>↺</button>
              <button type="button" id="rotate-right" class="rotate-btn" aria-label={t('fun.city.rotateRight')} title={t('fun.city.rotateRight')}>↻</button>
              <button class="speed-btn" data-speed="0">⏸</button>
              <button class="speed-btn active" data-speed="1">▶</button>
              <button class="speed-btn" data-speed="3">⏩</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { initCityGame } from '../../../games/city';
  initCityGame();
</script>

<style>
  .city-section {
    min-height: calc(100vh - var(--nav-height) - 200px);
    padding: var(--space-2xl) 0;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .game-container {
    max-width: 820px;
    margin: 0 auto;
  }

  .game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .game-header h1 {
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .city-emoji {
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.35); }
  }

  .scores {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .score-item {
    text-align: center;
  }

  .score-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .score-value {
    font-size: 1.35rem;
    font-weight: 700;
    color: #38bdf8;
  }

  .score-value.money {
    color: #4ade80;
  }

  .game-area {
    position: relative;
    background: var(--color-bg-secondary);
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid var(--color-border);
  }

  .canvas-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #game-canvas {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 76 / 45;
    cursor: pointer;
  }

  /* Keep tiles tappable on phones: minimum board size + horizontal pan */
  @media (max-width: 600px) {
    #game-canvas {
      min-width: 640px;
    }
  }

  .toast-area {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    pointer-events: none;
  }

  .toast-area :global(.toast) {
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    font-size: 0.8rem;
    padding: var(--space-xs) var(--space-md);
    border-radius: 999px;
    animation: toastIn 0.2s ease;
    white-space: nowrap;
  }

  @keyframes toastIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .game-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: var(--space-md);
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .overlay-content {
    text-align: center;
    margin: auto;
    padding: var(--space-xl);
    max-width: 520px;
  }

  .play-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .overlay-content h2 {
    font-size: 1.75rem;
    color: #ef4444;
    margin-bottom: var(--space-md);
  }

  .overlay-content p {
    margin-bottom: var(--space-lg);
  }

  .final-stats {
    font-size: 1.1rem;
  }

  .btn-large {
    padding: var(--space-md) var(--space-2xl);
    font-size: 1.1rem;
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .toolbar {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tool-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 64px;
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .tool-btn:hover {
    border-color: #38bdf8;
  }

  .tool-btn.active {
    border-color: #38bdf8;
    background: rgba(56, 189, 248, 0.12);
  }

  .tool-emoji {
    font-size: 1.3rem;
    line-height: 1;
  }

  .tool-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tool-cost {
    font-size: 0.7rem;
    font-weight: 700;
    color: #4ade80;
  }

  .side-controls {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .demand-meter {
    display: flex;
    gap: 6px;
  }

  .demand-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .demand-track {
    width: 12px;
    height: 44px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .demand-fill {
    width: 100%;
    height: 50%;
    transition: height 0.3s ease;
  }

  .demand-fill.res { background: #4ade80; }
  .demand-fill.com { background: #60a5fa; }
  .demand-fill.ind { background: #facc15; }

  .demand-fill.negative {
    opacity: 0.35;
  }

  .demand-label {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .speed-controls {
    display: flex;
    gap: var(--space-xs);
  }

  .speed-btn,
  .rotate-btn {
    width: 44px;
    height: 44px;
    font-size: 1.1rem;
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .speed-btn:hover,
  .speed-btn.active,
  .rotate-btn:hover {
    border-color: #38bdf8;
    background: rgba(56, 189, 248, 0.12);
  }

  @media (max-width: 600px) {
    .game-header {
      justify-content: center;
      text-align: center;
    }

    .game-header h1 {
      width: 100%;
      justify-content: center;
    }

    .scores {
      justify-content: center;
      gap: var(--space-md);
    }

    .controls {
      flex-direction: column;
      align-items: stretch;
    }

    .toolbar {
      justify-content: center;
    }

    .side-controls {
      justify-content: center;
    }
  }
</style>
