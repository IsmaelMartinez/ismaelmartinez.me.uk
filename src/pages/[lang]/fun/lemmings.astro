---
import Layout from '../../../layouts/Layout.astro';
import HighScoreTable from '../../../components/HighScoreTable.astro';
import { useTranslations, getLocalizedPath, locales } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';
import { LEVELS } from '../../../games/lemmings/levels';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const skills = [
  { id: 'blocker', emoji: '🚧', label: t('fun.lemmings.skillBlocker') },
  { id: 'digger', emoji: '⛏️', label: t('fun.lemmings.skillDigger') },
  { id: 'basher', emoji: '🔨', label: t('fun.lemmings.skillBasher') },
  { id: 'builder', emoji: '🧱', label: t('fun.lemmings.skillBuilder') },
  { id: 'floater', emoji: '☂️', label: t('fun.lemmings.skillFloater') }
];

// Per-level hints (a `TranslationKey` on the level) resolved server-side and
// handed to the game as `data-t-hint<index>` attributes; the game shows the
// current level's hint under the field. No hyphen before the index: `data-t-hint6`
// maps to `dataset.tHint6`, whereas `data-t-hint-6` would map to `tHint-6`
// (a digit after a hyphen keeps it).
const hintAttrs = Object.fromEntries(
  LEVELS.flatMap((level, i) => (level.hint ? [[`data-t-hint${i}`, t(level.hint)]] : []))
);
---

<Layout title="Critter Rescue" lang={lang}>
  <section class="lemmings-section">
    <div class="container">
      <a href={getLocalizedPath('/fun', lang)} class="back-link">← {t('fun.backToFun')}</a>

      <div
        class="game-container"
        id="lemmings-root"
        data-t-complete={t('fun.lemmings.complete')}
        data-t-failed={t('fun.lemmings.failed')}
        data-t-victory={t('fun.lemmings.victory')}
        data-t-complete-desc={t('fun.lemmings.completeDesc')}
        data-t-failed-desc={t('fun.lemmings.failedDesc')}
        data-t-victory-desc={t('fun.lemmings.victoryDesc')}
        data-t-level={t('fun.lemmings.level')}
        data-t-locked={t('fun.lemmings.locked')}
        {...hintAttrs}
      >
        <div class="game-header">
          <h1><span class="critter-emoji">🐛</span> {t('fun.lemmings.title')}</h1>
          <button
            id="sound-btn"
            class="btn sound-btn"
            aria-label={t('fun.arcade.soundOn')}
            data-sound-on={t('fun.arcade.soundOn')}
            data-sound-off={t('fun.arcade.soundOff')}
          >🔊</button>
          <div class="scores">
            <div class="score-item">
              <span class="score-label">{t('fun.lemmings.level')}</span>
              <span class="score-value"><span id="level-num">1</span>/{LEVELS.length}</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.lemmings.saved')}</span>
              <span class="score-value saved"><span id="saved-count">0</span>/<span id="needed-count">0</span></span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.lemmings.out')}</span>
              <span id="out-count" class="score-value">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.lemmings.best')}</span>
              <span id="best-level" class="score-value">0</span>
            </div>
          </div>
        </div>

        <div class="rescue-progress">
          <span class="progress-label">{t('fun.lemmings.progress')}</span>
          <div
            id="progress-bar"
            class="progress-track"
            role="progressbar"
            aria-label={t('fun.lemmings.progress')}
            aria-valuemin="0"
            aria-valuenow="0"
            aria-valuemax={Math.max(1, LEVELS[0].needed)}
          >
            <div id="progress-fill" class="progress-fill"></div>
          </div>
        </div>

        <div class="game-area">
          <canvas id="game-canvas"></canvas>
          <div id="start-overlay" class="game-overlay">
            <div class="overlay-content">
              <span class="play-icon">🐛</span>
              <p>{t('fun.lemmings.instructions')}</p>
              <div class="result-buttons">
                <button id="start-btn" class="btn btn-primary btn-large">{t('fun.lemmings.start')}</button>
                <button id="level-select-btn" class="btn btn-large">{t('fun.lemmings.selectLevel')}</button>
              </div>
            </div>
          </div>
          <div id="level-select-overlay" class="game-overlay" style="display: none;">
            <div class="overlay-content">
              <h2>{t('fun.lemmings.levelSelectTitle')}</h2>
              <div id="level-grid" class="level-grid"></div>
              <button id="level-back-btn" class="btn btn-large">← {t('fun.lemmings.back')}</button>
            </div>
          </div>
          <div id="result-overlay" class="game-overlay" style="display: none;">
            <div class="overlay-content">
              <span id="result-emoji" class="round-emoji">🎉</span>
              <h2 id="result-title"></h2>
              <p id="result-desc"></p>
              <HighScoreTable gameId="lemmings" lang={lang} accent="#84cc16" />
              <div class="result-buttons">
                <button
                  id="next-btn"
                  class="btn btn-primary btn-large"
                  data-next-level={t('fun.lemmings.nextLevel')}
                  data-play-again={t('fun.lemmings.playAgain')}
                >{t('fun.lemmings.nextLevel')}</button>
                <button id="retry-btn" class="btn btn-primary btn-large" style="display: none;">{t('fun.lemmings.retry')}</button>
              </div>
            </div>
          </div>
        </div>

        <p id="level-hint" class="level-hint" hidden></p>

        <div class="skill-bar">
          {skills.map((skill, i) => (
            <button class={`skill-btn${i === 0 ? ' active' : ''}`} data-skill={skill.id} disabled>
              <span class="skill-emoji">{skill.emoji}</span>
              <span class="skill-name">{skill.label}</span>
              <span class="skill-count">0</span>
            </button>
          ))}
        </div>

        <div class="controls">
          <div class="control-group">
            <label for="spawn-slider">{t('fun.lemmings.spawnRate')}</label>
            <input type="range" id="spawn-slider" min="1" max="10" value="1" />
          </div>
          <button id="nuke-btn" class="btn nuke-btn">💥 {t('fun.lemmings.nuke')}</button>
        </div>

        <p class="keys-hint">{t('fun.lemmings.hint')}</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // ClientRouter swaps don't re-run this module; re-init after each swap.
  // initLemmingsGame no-ops on pages without a fresh game root.
  import { initLemmingsGame } from '../../../games/lemmings';
  initLemmingsGame();
  document.addEventListener('astro:after-swap', initLemmingsGame);
</script>

<style>
  .lemmings-section {
    min-height: calc(100vh - var(--nav-height) - 200px);
    padding: var(--space-2xl) 0;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .game-container {
    max-width: 720px;
    margin: 0 auto;
  }

  .game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .game-header h1 {
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .critter-emoji {
    display: inline-block;
    animation: wiggle 1.4s ease-in-out infinite;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(-8deg); }
    50% { transform: rotate(8deg); }
  }

  .scores {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .score-item {
    text-align: center;
  }

  .score-label {
    display: block;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .score-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .score-value.saved {
    color: #84cc16;
  }

  .rescue-progress {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .progress-label {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .progress-track {
    position: relative;
    flex: 1;
    height: 10px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    border-radius: 999px;
    background: linear-gradient(90deg, #65a30d, #84cc16);
    transition: width 0.25s ease;
  }

  .progress-track.is-complete .progress-fill {
    background: linear-gradient(90deg, #22c55e, #a3e635);
    box-shadow: 0 0 8px rgba(132, 204, 22, 0.6);
  }

  .game-area {
    position: relative;
    background: var(--color-bg-secondary);
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid var(--color-border);
  }

  #game-canvas {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 8 / 5;
    /* Tapping the field assigns skills, so don't let it scroll the page. */
    touch-action: none;
    image-rendering: pixelated;
    cursor: pointer;
  }

  .game-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: var(--space-md);
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .overlay-content {
    text-align: center;
    margin: auto;
    padding: var(--space-xl);
    max-width: 480px;
  }

  .play-icon,
  .round-emoji {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .overlay-content h2 {
    font-size: 1.75rem;
    color: #a3e635;
    margin-bottom: var(--space-md);
  }

  .overlay-content p {
    margin-bottom: var(--space-xl);
    line-height: 1.6;
  }

  .result-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-large {
    padding: var(--space-md) var(--space-2xl);
    font-size: 1.1rem;
  }

  .level-hint {
    margin-top: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: rgba(132, 204, 22, 0.12);
    border: 1px solid rgba(132, 204, 22, 0.35);
    border-radius: 0.6rem;
    color: var(--color-text);
    font-size: 0.85rem;
    line-height: 1.4;
    text-align: center;
  }

  .level-hint[hidden] {
    display: none;
  }

  .level-hint::before {
    content: '💡 ';
  }

  .level-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(56px, 1fr));
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .level-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    aspect-ratio: 1;
    padding: var(--space-sm);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .level-cell:hover:not(:disabled) {
    border-color: #84cc16;
    background: rgba(132, 204, 22, 0.16);
  }

  .level-cell:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .level-cell .level-lock {
    font-size: 0.85rem;
  }

  .skill-bar {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .skill-btn {
    flex: 1;
    min-width: 92px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .skill-btn:hover:not(:disabled) {
    border-color: #84cc16;
  }

  .skill-btn.active:not(:disabled) {
    border-color: #84cc16;
    background: rgba(132, 204, 22, 0.16);
  }

  .skill-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .skill-emoji {
    font-size: 1.2rem;
    line-height: 1;
  }

  .skill-name {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
  }

  .skill-count {
    font-size: 0.85rem;
    font-weight: 700;
    color: #84cc16;
  }

  .controls {
    display: flex;
    align-items: end;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .control-group {
    flex: 1;
    min-width: 160px;
  }

  .control-group label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .control-group input[type='range'] {
    width: 100%;
    accent-color: #84cc16;
  }

  .nuke-btn {
    padding: var(--space-md) var(--space-xl);
    font-weight: 700;
    letter-spacing: 0.05em;
    background: rgba(239, 68, 68, 0.15);
    border: 2px solid #ef4444;
    color: #fca5a5;
  }

  .nuke-btn:hover {
    background: rgba(239, 68, 68, 0.28);
  }

  .keys-hint {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 600px) {
    .game-header {
      justify-content: center;
      text-align: center;
    }

    .game-header h1 {
      width: 100%;
      justify-content: center;
    }

    .scores {
      gap: var(--space-md);
      justify-content: center;
    }

    .controls {
      flex-direction: column;
      align-items: stretch;
    }

    .nuke-btn {
      width: 100%;
    }

    .overlay-content {
      padding: var(--space-md);
    }

    .play-icon,
    .round-emoji {
      font-size: 2.75rem;
      margin-bottom: var(--space-sm);
    }

    .result-buttons {
      flex-direction: column;
    }

    .result-buttons .btn-large {
      width: 100%;
    }
  }
</style>
