---
/**
 * Old-school per-device high-score table for an arcade game.
 *
 * Drop inside a game-over overlay; it stays hidden until the game calls
 * `initScoreboard(...)` from src/games/engine/scoreboard.ts and then
 * `show(score)` when a run ends. Rows are rendered at runtime from
 * localStorage, so their styles are declared globally under `.hs-panel`.
 */
import { useTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  /** Table identity in localStorage, e.g. "snake". */
  gameId: string;
  lang: Locale;
  /** Accent colour matching the game's cabinet. */
  accent?: string;
}

const { gameId, lang, accent = '#22c55e' } = Astro.props;
const t = useTranslations(lang);
---

<div class="hs-panel" id="highscores" data-hs-game={gameId} style={`--hs-accent: ${accent}`} hidden>
  <form class="hs-entry" hidden>
    <p class="hs-new">{t('fun.arcade.newHighScore')}</p>
    <label class="hs-prompt" for={`hs-input-${gameId}`}>{t('fun.arcade.enterInitials')}</label>
    <div class="hs-entry-row">
      <input
        id={`hs-input-${gameId}`}
        class="hs-input"
        type="text"
        maxlength="3"
        autocomplete="off"
        autocapitalize="characters"
        spellcheck="false"
        placeholder="AAA"
      />
      <button type="submit" class="hs-ok">OK</button>
    </div>
  </form>
  <h3 class="hs-title">{t('fun.arcade.highScores')}</h3>
  <ol class="hs-list"></ol>
  <p class="hs-empty" hidden>{t('fun.arcade.noScores')}</p>
</div>

<style is:global>
  /* The panel is a dark CRT screen in both site themes, like the arcade
     cabinets, so it can sit on game overlays and light cards alike. */
  .hs-panel {
    font-family: var(--font-mono);
    margin: var(--space-lg) auto;
    max-width: 300px;
    padding: var(--space-md) var(--space-lg);
    text-align: center;
    background: linear-gradient(180deg, #0c1018 0%, #10141f 100%);
    border: 1px solid color-mix(in srgb, var(--hs-accent) 45%, transparent);
    border-radius: 0.6rem;
    box-shadow:
      inset 0 0 24px rgba(0, 0, 0, 0.6),
      0 0 14px color-mix(in srgb, var(--hs-accent) 18%, transparent);
  }

  .hs-panel .hs-new {
    color: var(--hs-accent);
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    animation: hsBlink 1s step-end infinite;
    margin-bottom: var(--space-sm);
  }

  @keyframes hsBlink {
    50% { opacity: 0.35; }
  }

  .hs-panel .hs-prompt {
    display: block;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-sm);
  }

  .hs-panel .hs-entry-row {
    display: flex;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .hs-panel .hs-input {
    width: 5.5ch;
    padding: 0.35rem 0.5rem;
    font-family: inherit;
    font-size: 1.4rem;
    font-weight: 700;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: var(--hs-accent);
    background: rgba(0, 0, 0, 0.6);
    border: 2px solid var(--hs-accent);
    border-radius: 0.4rem;
    caret-color: var(--hs-accent);
  }

  .hs-panel .hs-input:focus {
    outline: 2px solid var(--hs-accent);
    outline-offset: 2px;
  }

  .hs-panel .hs-ok {
    padding: 0.35rem 0.9rem;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    color: #0a0a0a;
    background: var(--hs-accent);
    border: none;
    border-radius: 0.4rem;
    cursor: pointer;
  }

  .hs-panel .hs-ok:hover {
    filter: brightness(1.15);
  }

  .hs-panel .hs-title {
    color: var(--hs-accent);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    text-shadow: 0 0 8px var(--hs-accent);
    margin-bottom: var(--space-sm);
  }

  .hs-panel .hs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 12.5rem;
    overflow-y: auto;
  }

  .hs-panel .hs-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    padding: 0.15rem 0.4rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    white-space: pre;
  }

  .hs-panel .hs-row.hs-current {
    color: var(--hs-accent);
    background: color-mix(in srgb, var(--hs-accent) 16%, transparent);
    border-radius: 0.25rem;
    animation: hsBlink 1s step-end 3;
  }

  .hs-panel .hs-rank {
    width: 2.5ch;
    text-align: right;
    opacity: 0.7;
  }

  .hs-panel .hs-initials {
    flex: 1;
    text-align: left;
    letter-spacing: 0.3em;
  }

  .hs-panel .hs-empty {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
</style>
