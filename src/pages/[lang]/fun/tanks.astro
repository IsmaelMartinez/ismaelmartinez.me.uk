---
import Layout from '../../../layouts/Layout.astro';
import HighScoreTable from '../../../components/HighScoreTable.astro';
import { useTranslations, getLocalizedPath, locales } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const weapons = [
  { id: 'missile', emoji: '🚀', label: t('fun.tanks.weaponMissile') },
  { id: 'heavy', emoji: '💣', label: t('fun.tanks.weaponHeavy') },
  { id: 'mirv', emoji: '🎇', label: t('fun.tanks.weaponMirv') },
  { id: 'bounce', emoji: '🎾', label: t('fun.tanks.weaponBounce') }
];
---

<Layout title="Tank Duel" lang={lang}>
  <section class="tanks-section">
    <div class="container">
      <a href={getLocalizedPath('/fun', lang)} class="back-link">← {t('fun.backToFun')}</a>

      <div
        class="game-container"
        id="tanks-root"
        data-t-player1={t('fun.tanks.player1')}
        data-t-player2={t('fun.tanks.player2')}
        data-t-cpu={t('fun.tanks.cpu')}
        data-t-wins-round={t('fun.tanks.winsRound')}
        data-t-wins-match={t('fun.tanks.winsMatch')}
        data-t-draw={t('fun.tanks.draw')}
        data-t-wind={t('fun.tanks.wind')}
        data-t-match-score={t('fun.tanks.matchScore')}
      >
        <div class="game-header">
          <h1><span class="tank-emoji">🎯</span> {t('fun.tanks.title')}</h1>
          <button
            id="music-btn"
            class="btn sound-btn"
            data-glyph-on="🎵"
            data-glyph-off="🎵"
            aria-label={t('fun.arcade.musicOn')}
            data-music-on={t('fun.arcade.musicOn')}
            data-music-off={t('fun.arcade.musicOff')}
          >🎵</button>
          <button
            id="sfx-btn"
            class="btn sound-btn"
            data-glyph-on="🔊"
            data-glyph-off="🔇"
            aria-label={t('fun.arcade.sfxOn')}
            data-sfx-on={t('fun.arcade.sfxOn')}
            data-sfx-off={t('fun.arcade.sfxOff')}
          >🔊</button>
          <div class="scores">
            <div class="score-item">
              <span class="score-label" id="p1-label">{t('fun.tanks.player1')}</span>
              <span id="p1-wins" class="score-value p1">0</span>
            </div>
            <div class="score-item">
              <span class="score-label" id="p2-label">{t('fun.tanks.player2')}</span>
              <span id="p2-wins" class="score-value p2">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.tanks.victories')}</span>
              <span id="victories" class="score-value">0</span>
            </div>
          </div>
        </div>

        <div class="game-area">
          <canvas id="game-canvas"></canvas>
          <div id="start-overlay" class="game-overlay">
            <div class="overlay-content">
              <span class="play-icon">🎯</span>
              <p>{t('fun.tanks.instructions')}</p>
              <div class="difficulty-select" role="group" aria-label={t('fun.tanks.difficulty')}>
                <span class="difficulty-label">{t('fun.tanks.difficulty')}</span>
                <div class="difficulty-buttons">
                  <button type="button" class="difficulty-btn" data-difficulty="rookie" aria-pressed="false">{t('fun.tanks.difficultyRookie')}</button>
                  <button type="button" class="difficulty-btn active" data-difficulty="gunner" aria-pressed="true">{t('fun.tanks.difficultyGunner')}</button>
                  <button type="button" class="difficulty-btn" data-difficulty="veteran" aria-pressed="false">{t('fun.tanks.difficultyVeteran')}</button>
                </div>
              </div>
              <div class="arena-select" role="group" aria-label={t('fun.tanks.arena')}>
                <span class="arena-label">{t('fun.tanks.arena')}</span>
                <div class="arena-buttons">
                  <button type="button" class="arena-btn active" data-arena="hills" aria-pressed="true">{t('fun.tanks.arenaHills')}</button>
                  <button type="button" class="arena-btn" data-arena="canyon" aria-pressed="false">{t('fun.tanks.arenaCanyon')}</button>
                  <button type="button" class="arena-btn" data-arena="mesa" aria-pressed="false">{t('fun.tanks.arenaMesa')}</button>
                  <button type="button" class="arena-btn" data-arena="ridges" aria-pressed="false">{t('fun.tanks.arenaRidges')}</button>
                  <button type="button" class="arena-btn" data-arena="bunker" aria-pressed="false">{t('fun.tanks.arenaBunker')}</button>
                </div>
              </div>
              <div class="mode-buttons">
                <button id="vs-cpu-btn" class="btn btn-primary btn-large">{t('fun.tanks.vsCpu')}</button>
                <button id="two-player-btn" class="btn btn-primary btn-large">{t('fun.tanks.twoPlayer')}</button>
              </div>
            </div>
          </div>
          <div id="round-overlay" class="game-overlay" style="display: none;">
            <div class="overlay-content">
              <span id="round-emoji" class="round-emoji">💥</span>
              <h2 id="round-message"></h2>
              <p id="match-score" class="match-score" style="display: none;"></p>
              <HighScoreTable gameId="tanks" lang={lang} accent="#3b82f6" />
              <button id="next-round-btn" class="btn btn-primary btn-large">{t('fun.tanks.nextRound')}</button>
              <button id="play-again-btn" class="btn btn-primary btn-large" style="display: none;">{t('fun.tanks.playAgain')}</button>
            </div>
          </div>
        </div>

        <div class="weapon-bar">
          {weapons.map((weapon, i) => (
            <button class={`weapon-btn${i === 0 ? ' active' : ''}`} data-weapon={weapon.id} disabled>
              <span class="weapon-emoji">{weapon.emoji}</span>
              <span class="weapon-name">{weapon.label}</span>
              <span class="weapon-ammo">∞</span>
            </button>
          ))}
        </div>

        <div class="controls">
          <div class="control-group">
            <label for="angle-slider">{t('fun.tanks.angle')} <span id="angle-value" class="control-value">60°</span></label>
            <input type="range" id="angle-slider" min="5" max="175" value="60" />
          </div>
          <div class="control-group">
            <label for="power-slider">{t('fun.tanks.power')} <span id="power-value" class="control-value">55</span></label>
            <input type="range" id="power-slider" min="10" max="100" value="55" />
          </div>
          <button id="fire-btn" class="btn btn-primary fire-btn">{t('fun.tanks.fire')}</button>
        </div>

        <p class="keys-hint">{t('fun.tanks.keys')}</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // ClientRouter swaps don't re-execute this module, so returning to the
  // page would otherwise leave a dead, unwired game board. Re-init after
  // every swap; initTanksGame no-ops on pages without a fresh game root.
  import { initTanksGame } from '../../../games/tanks';
  initTanksGame();
  document.addEventListener('astro:after-swap', initTanksGame);
</script>

<style>
  .tanks-section {
    min-height: calc(100vh - var(--nav-height) - 200px);
    padding: var(--space-2xl) 0;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .game-container {
    max-width: 850px;
    margin: 0 auto;
  }

  .game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .game-header h1 {
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .tank-emoji {
    animation: recoil 2s ease-in-out infinite;
  }

  @keyframes recoil {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(-3px); }
  }

  .scores {
    display: flex;
    gap: var(--space-lg);
  }

  .score-item {
    text-align: center;
  }

  .score-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .score-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .score-value.p1 {
    color: #38bdf8;
  }

  .score-value.p2 {
    color: #f87171;
  }

  .game-area {
    position: relative;
    background: var(--color-bg-secondary);
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid var(--color-border);
  }

  #game-canvas {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    /* Dragging on the battlefield aims the shot, so don't scroll the page */
    touch-action: none;
    cursor: crosshair;
  }

  .game-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: var(--space-md);
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(4px);
  }

  .overlay-content {
    text-align: center;
    margin: auto;
    padding: var(--space-xl);
    max-width: 480px;
  }

  .play-icon,
  .match-score {
    font-size: 1.05rem;
    font-weight: 700;
    color: #fbbf24;
    margin-bottom: var(--space-md);
  }

  .round-emoji {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .overlay-content h2 {
    font-size: 1.75rem;
    color: #60a5fa;
    margin-bottom: var(--space-xl);
  }

  .overlay-content p {
    margin-bottom: var(--space-xl);
  }

  .difficulty-select,
  .arena-select {
    margin-bottom: var(--space-lg);
  }

  .difficulty-label,
  .arena-label {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-sm);
  }

  .difficulty-buttons,
  .arena-buttons {
    display: inline-flex;
    gap: var(--space-xs);
    padding: 4px;
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.7rem;
  }

  .difficulty-btn,
  .arena-btn {
    padding: var(--space-xs) var(--space-md);
    min-height: 40px;
    background: transparent;
    border: none;
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .difficulty-btn:hover,
  .arena-btn:hover {
    color: var(--color-text);
  }

  .difficulty-btn.active,
  .arena-btn.active {
    background: rgba(37, 99, 235, 0.18);
    color: var(--color-text);
    box-shadow: inset 0 0 0 2px var(--color-accent);
  }

  .mode-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-large {
    padding: var(--space-md) var(--space-2xl);
    font-size: 1.1rem;
  }

  .weapon-bar {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .weapon-btn {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    /* Keep a comfortable tap height on phones (was 30px tall) */
    min-height: 44px;
    padding: var(--space-xs) var(--space-md);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .weapon-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
  }

  .weapon-btn.active {
    border-color: var(--color-accent);
    background: rgba(37, 99, 235, 0.14);
  }

  .weapon-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .weapon-emoji {
    font-size: 1.1rem;
    line-height: 1;
  }

  .weapon-name {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .weapon-ammo {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .controls {
    display: flex;
    align-items: end;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .control-group {
    flex: 1;
    min-width: 160px;
  }

  .control-group label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .control-value {
    font-weight: 700;
    color: var(--color-text);
  }

  .control-group input[type='range'] {
    width: 100%;
    accent-color: var(--color-accent);
  }

  .control-group input[type='range']:disabled {
    opacity: 0.4;
  }

  .fire-btn {
    padding: var(--space-md) var(--space-2xl);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .fire-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .keys-hint {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 600px) {
    .game-header {
      justify-content: center;
      text-align: center;
    }

    .game-header h1 {
      width: 100%;
      justify-content: center;
    }

    .controls {
      flex-direction: column;
      align-items: stretch;
    }

    .fire-btn {
      width: 100%;
    }

    .overlay-content {
      padding: var(--space-md);
    }

    .play-icon,
    .round-emoji {
      font-size: 2.75rem;
      margin-bottom: var(--space-sm);
    }

    .overlay-content p {
      margin-bottom: var(--space-md);
    }

    .mode-buttons {
      flex-direction: column;
    }

    .mode-buttons .btn-large {
      width: 100%;
    }

    .btn-large {
      padding: var(--space-md) var(--space-lg);
    }

    .keys-hint {
      display: none;
    }
  }
</style>
