---
import Layout from '../../../layouts/Layout.astro';
import HighScoreTable from '../../../components/HighScoreTable.astro';
import { useTranslations, locales } from '../../../i18n/translations';
import type { Locale } from '../../../i18n/translations';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);
---

<Layout title="Line Hold" lang={lang}>
  <section class="towerdefense-section">
    <div class="container">
      <div
        class="game-container"
        id="towerdefense-root"
        data-t-wave-in={t('fun.towerdefense.waveIn')}
        data-t-wave-now={t('fun.towerdefense.waveNow')}
        data-t-wave-cleared={t('fun.towerdefense.waveCleared')}
        data-t-interest={t('fun.towerdefense.interest')}
        data-t-new-record={t('fun.towerdefense.newRecord')}
        data-t-breach={t('fun.towerdefense.breach')}
        data-t-victory={t('fun.towerdefense.victory')}
        data-t-victory-desc={t('fun.towerdefense.victoryDesc')}
        data-t-game-over={t('fun.towerdefense.gameOver')}
        data-t-game-over-desc={t('fun.towerdefense.gameOverDesc')}
        data-t-max-level={t('fun.towerdefense.maxLevel')}
        data-t-level={t('fun.towerdefense.level')}
        data-t-tower-bolt={t('fun.towerdefense.towerBolt')}
        data-t-tower-blast={t('fun.towerdefense.towerBlast')}
        data-t-tower-frost={t('fun.towerdefense.towerFrost')}
      >
        <div class="game-header">
          <h1><span class="td-emoji">🏰</span> {t('fun.towerdefense.title')}</h1>
          <button
            id="sound-btn"
            class="btn sound-btn"
            aria-label={t('fun.arcade.soundOn')}
            data-sound-on={t('fun.arcade.soundOn')}
            data-sound-off={t('fun.arcade.soundOff')}
          >🔊</button>
          <div class="scores">
            <div class="score-item">
              <span class="score-label">{t('fun.towerdefense.funds')}</span>
              <span id="money" class="score-value money">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.towerdefense.lives')}</span>
              <span id="lives" class="score-value lives">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.towerdefense.wave')}</span>
              <span id="wave-num" class="score-value">—</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.towerdefense.score')}</span>
              <span id="score" class="score-value">0</span>
            </div>
            <div class="score-item">
              <span class="score-label">{t('fun.towerdefense.record')}</span>
              <span id="record" class="score-value">0</span>
            </div>
          </div>
        </div>

        <div class="game-area">
          <div class="canvas-scroll" id="canvas-scroll">
            <canvas id="game-canvas"></canvas>
          </div>
          <div id="toast-area" class="toast-area"></div>

          <div id="start-overlay" class="game-overlay">
            <div class="overlay-content">
              <span class="play-icon">🏰</span>
              <h2>{t('fun.towerdefense.title')}</h2>
              <p class="instructions">{t('fun.towerdefense.instructions')}</p>
              <button id="start-btn" class="btn btn-primary btn-large">
                {t('fun.towerdefense.start')}
              </button>
            </div>
          </div>

          <div id="over-overlay" class="game-overlay" style="display: none;">
            <div class="overlay-content">
              <span id="over-icon" class="play-icon">💥</span>
              <h2 id="over-title"></h2>
              <p id="over-desc"></p>
              <p class="final-stats">
                {t('fun.towerdefense.finalScore')}: <strong id="final-score">0</strong>
              </p>
              <HighScoreTable gameId="towerdefense" lang={lang} accent="#f59e0b" />
              <button id="again-btn" class="btn btn-primary btn-large">
                {t('fun.towerdefense.playAgain')}
              </button>
            </div>
          </div>
        </div>

        <div class="controls">
          <div class="tool-bar">
            <button class="tower-tool active" data-kind="bolt" disabled>
              <span class="tool-swatch swatch-bolt"></span>
              <span class="tool-name">{t('fun.towerdefense.towerBolt')}</span>
              <span class="tool-cost">70</span>
            </button>
            <button class="tower-tool" data-kind="blast" disabled>
              <span class="tool-swatch swatch-blast"></span>
              <span class="tool-name">{t('fun.towerdefense.towerBlast')}</span>
              <span class="tool-cost">110</span>
            </button>
            <button class="tower-tool" data-kind="frost" disabled>
              <span class="tool-swatch swatch-frost"></span>
              <span class="tool-name">{t('fun.towerdefense.towerFrost')}</span>
              <span class="tool-cost">90</span>
            </button>
          </div>
          <div class="action-bar">
            <span id="tower-info" class="tower-info" hidden></span>
            <button
              id="upgrade-btn"
              class="btn upgrade-btn"
              title={t('fun.towerdefense.upgrade')}
              hidden
            ></button>
            <button id="wave-btn" class="btn wave-btn" disabled>▶</button>
          </div>
        </div>
        <p class="hint">{t('fun.towerdefense.hint')}</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  // ClientRouter swaps don't re-execute this module, so returning to the
  // page would otherwise leave a dead, unwired game board. Re-init after
  // every swap; initTowerDefenseGame no-ops on pages without a fresh root.
  import { initTowerDefenseGame } from '../../../games/towerdefense';
  initTowerDefenseGame();
  document.addEventListener('astro:after-swap', initTowerDefenseGame);
</script>

<style>
  .towerdefense-section {
    min-height: calc(100vh - var(--nav-height) - 200px);
    padding: var(--space-2xl) 0;
  }

  .game-container {
    max-width: 880px;
    margin: 0 auto;
  }

  .game-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }

  .game-header h1 {
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: 0;
  }

  .td-emoji {
    animation: bannerWave 3s ease-in-out infinite;
  }

  @keyframes bannerWave {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(-6deg); }
  }

  .scores {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .score-item {
    text-align: center;
  }

  .score-label {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .score-value {
    font-size: 1.35rem;
    font-weight: 700;
    color: #f59e0b;
  }

  .score-value.money {
    color: #4ade80;
  }

  .score-value.lives {
    color: #f87171;
  }

  .game-area {
    position: relative;
    background: var(--color-bg-secondary);
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid var(--color-border);
  }

  .canvas-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  #game-canvas {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 608 / 382;
    cursor: crosshair;
  }

  @media (max-width: 600px) {
    #game-canvas {
      min-width: 560px;
    }
  }

  .toast-area {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    pointer-events: none;
  }

  .toast-area :global(.toast) {
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    font-size: 0.8rem;
    padding: var(--space-xs) var(--space-md);
    border-radius: 999px;
    animation: toastIn 0.2s ease;
    white-space: nowrap;
  }

  @keyframes toastIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .game-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow-y: auto;
    padding: var(--space-md);
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  .overlay-content {
    text-align: center;
    margin: auto;
    padding: var(--space-xl);
    max-width: 560px;
  }

  .overlay-content h2 {
    margin: 0 0 var(--space-sm);
    color: #f59e0b;
  }

  .overlay-content p {
    margin: 0 0 var(--space-md);
    color: var(--color-text);
  }

  .overlay-content .instructions {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .play-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--space-md);
  }

  .final-stats {
    font-size: 1.1rem;
  }

  .final-stats strong {
    color: #f59e0b;
  }

  .controls {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: var(--space-md);
    margin-top: var(--space-lg);
    flex-wrap: wrap;
  }

  .tool-bar {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .tower-tool {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 3px;
    min-width: 76px;
    padding: var(--space-xs) var(--space-sm);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.15s ease;
    font-size: 0.7rem;
  }

  .tower-tool:hover:not(:disabled) {
    border-color: #f59e0b;
  }

  .tower-tool.active {
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.12);
  }

  .tower-tool:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .tool-swatch {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    transform: rotate(45deg) scale(0.85);
  }

  .swatch-bolt {
    background: #f59e0b;
  }

  .swatch-blast {
    background: #f43f5e;
  }

  .swatch-frost {
    background: #38bdf8;
  }

  .tool-name {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  .tool-cost {
    color: #4ade80;
    font-size: 0.72rem;
  }

  .action-bar {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .tower-info {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #7dd3fc;
  }

  .upgrade-btn,
  .wave-btn {
    min-height: 44px;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-border);
    border-radius: 0.6rem;
    color: var(--color-text);
    cursor: pointer;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.75rem;
    transition: all 0.15s ease;
  }

  .upgrade-btn:not(:disabled):hover {
    border-color: #7dd3fc;
  }

  .wave-btn {
    min-width: 150px;
  }

  .wave-btn:not(:disabled) {
    border-color: #f59e0b;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.35);
  }

  .upgrade-btn:disabled,
  .wave-btn:disabled {
    cursor: not-allowed;
    opacity: 0.75;
  }

  .hint {
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-align: center;
  }

  @media (max-width: 600px) {
    .game-header {
      justify-content: center;
      text-align: center;
    }

    .scores {
      justify-content: center;
      gap: var(--space-md);
    }

    .controls {
      flex-direction: column;
      align-items: stretch;
    }

    .tool-bar,
    .action-bar {
      justify-content: center;
    }
  }
</style>
