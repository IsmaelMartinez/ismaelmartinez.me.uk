---
import Layout from '../../layouts/Layout.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { useTranslations, locales } from '../../i18n/translations';
import type { Locale } from '../../i18n/translations';
import { socialLinks } from '../../data/links';
import { personJsonLd, toJsonLd } from '../../data/person';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const t = useTranslations(lang);

const focusAreas = [
  { icon: '🤖', title: t('about.focus1Title'), body: t('about.focus1') },
  { icon: '🧭', title: t('about.focus2Title'), body: t('about.focus2') },
  { icon: '🌍', title: t('about.focus3Title'), body: t('about.focus3') },
];

const aboutJsonLd = {
  ...personJsonLd,
  "description": t('about.description'),
  "knowsAbout": ["Software Development", "Responsible AI", "Agentic Systems", "Event-Driven Architecture", "Observability", "Cloud Architecture", "DevOps", "Open Source", "Platform Engineering", "Accessibility", "TypeScript", "JavaScript", "AWS"]
};
---

<Layout title={t('about.title')} description={t('about.description')} lang={lang}>
  <script slot="head" type="application/ld+json" set:html={toJsonLd(aboutJsonLd)} />

  <section class="section">
    <div class="container">
      <header class="page-header">
        <h1 class="page-title">{t('about.title')}</h1>
        <p class="page-description">{t('about.description')}</p>
      </header>

      <div class="about-content">
        <div class="about-section">
          <h2>{t('about.bioTitle')}</h2>
          <p>{t('about.bio')}</p>
        </div>

        <div class="about-section">
          <h2>{t('about.focusTitle')}</h2>
          <div class="grid focus-grid">
            {focusAreas.map(area => (
              <div class="card focus-card">
                <span class="focus-icon" aria-hidden="true">{area.icon}</span>
                <h3>{area.title}</h3>
                <p>{area.body}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="about-section">
          <h2>{t('about.careerTitle')}</h2>
          <ul class="career-list">
            <li>{t('about.career1')}</li>
            <li>{t('about.career2')}</li>
            <li>{t('about.career3')}</li>
            <li>{t('about.career4')}</li>
          </ul>
        </div>

        <div class="about-section">
          <h2>{t('about.interestsTitle')}</h2>
          <p>{t('about.interests')}</p>
        </div>

        <div class="about-section">
          <h2>{t('about.elsewhereTitle')}</h2>
          <div class="social-row">
            {socialLinks.map(link => (
              <a href={link.url} class="social-pill" target="_blank" rel="noopener noreferrer">
                <span aria-hidden="true">{link.icon}</span>
                {link.name}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <ContactCTA lang={lang} />
</Layout>

<style>
  .page-header {
    margin-bottom: var(--space-2xl);
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .page-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .about-content {
    max-width: 800px;
  }

  .about-section {
    margin-bottom: var(--space-2xl);
  }

  .about-section h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .about-section > p {
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .focus-grid {
    grid-template-columns: 1fr;
  }

  .focus-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: var(--space-sm) 0;
  }

  .focus-card p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .focus-icon {
    font-size: 1.5rem;
  }

  @media (min-width: 768px) {
    .focus-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .career-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .career-list li {
    padding: var(--space-md) var(--space-lg);
    background: var(--color-bg-secondary);
    border: var(--frame-width) solid var(--color-frame);
    border-radius: var(--radius);
    box-shadow: var(--shadow-btn);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: var(--color-bg-secondary);
    border: var(--frame-width) solid var(--color-frame);
    border-radius: var(--radius);
    box-shadow: var(--shadow-btn);
    color: var(--color-text);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: transform 0.08s ease, box-shadow 0.08s ease, color 0.2s ease;
  }

  .social-pill:hover {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-btn-pressed);
    color: var(--color-accent);
  }
</style>
