---
import type { SocialLink } from '../data/links';

interface Props {
  link: SocialLink;
  lang: 'en' | 'es' | 'cat';
}

const { link, lang } = Astro.props;
---

<a href={link.url} class="link-card" target="_blank" rel="noopener noreferrer">
  <span class="link-card-icon">{link.icon}</span>
  <div class="link-card-content">
    <h3>{link.name}</h3>
    <p>{link.description[lang]}</p>
  </div>
  <span class="link-arrow">→</span>
</a>

<style>
  /* Frame, shadow, and typography come from the global .link-card styles */
  .link-card {
    color: var(--color-text);
  }

  .link-card-icon {
    flex-shrink: 0;
  }

  .link-card-content {
    flex-grow: 1;
  }

  .link-arrow {
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .link-card:hover .link-arrow {
    color: var(--color-accent);
  }
</style>
