---
interface Props {
  id: string;
  title: string;
  /** Translated one-line pitch shown on the cabinet base. */
  tagline: string;
  /** Translated genre chip, e.g. "Artillery". */
  genre: string;
  /** Translated players chip, e.g. "1–2 players". */
  players: string;
  href: string;
  color: string;
  icon: string;
  /** localStorage key of the game's saved best score, shown on the screen. */
  scoreKey: string;
  /** Translated label for the best-score readout. */
  bestLabel: string;
  /** Translated "New" ribbon text; omit to hide the ribbon. */
  newBadge?: string;
}

const { id, title, tagline, genre, players, href, color, icon, scoreKey, bestLabel, newBadge } =
  Astro.props;
---

<a
  href={href}
  class="arcade-cabinet"
  data-game={id}
  style={`--cabinet-color: ${color}; --cabinet-glow: ${color}40;`}
>
  {newBadge && <span class="new-ribbon">{newBadge}</span>}

  <div class="cabinet-top">
    <div class="cabinet-marquee">
      <span class="marquee-text">{title}</span>
    </div>
  </div>

  <div class="cabinet-screen">
    <div class="screen-bezel">
      <div class="screen-content">
        <div class="screen-scanlines"></div>
        <div class="screen-icon">{icon}</div>
        <div class="screen-text">
          <p class="best-score">
            {bestLabel} <span class="best-value" data-score-key={scoreKey}>000000</span>
          </p>
          <p class="blink">PRESS START</p>
        </div>
      </div>
    </div>
  </div>

  <div class="cabinet-controls">
    <div class="joystick"></div>
    <div class="buttons">
      <div class="btn-arcade btn-a"></div>
      <div class="btn-arcade btn-b"></div>
    </div>
  </div>

  <div class="cabinet-base">
    <p class="game-desc">{tagline}</p>
    <div class="cabinet-chips">
      <span class="chip chip-genre">{genre}</span>
      <span class="chip chip-players">{players}</span>
    </div>
  </div>
</a>

<style>
  .arcade-cabinet {
    display: flex;
    flex-direction: column;
    width: 220px;
    max-width: 100%;
    background: linear-gradient(180deg, #2a2a2a 0%, #1a1a1a 100%);
    border-radius: 12px 12px 8px 8px;
    padding: 12px;
    text-decoration: none;
    /* The cabinet body is always dark, whatever the site theme, so its text
       colours are fixed rather than theme tokens (which flip to ink in light
       mode and vanish against the dark panels). */
    color: #e4ebf6;
    transition: all 0.3s ease;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .arcade-cabinet::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, var(--cabinet-color), transparent, var(--cabinet-color));
    border-radius: 14px 14px 10px 10px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .arcade-cabinet:hover::before,
  .arcade-cabinet:focus-visible::before {
    opacity: 1;
  }

  .arcade-cabinet:hover,
  .arcade-cabinet:focus-visible {
    transform: translateY(-8px) scale(1.02);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.6),
      0 0 60px var(--cabinet-glow),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .arcade-cabinet:hover .screen-content {
    background: radial-gradient(circle at center, var(--cabinet-glow) 0%, #000 70%);
  }

  .arcade-cabinet:hover .blink {
    animation: blink 0.5s step-end infinite;
  }

  .arcade-cabinet:hover .screen-icon {
    animation: bounce 0.5s ease infinite;
  }

  .new-ribbon {
    position: absolute;
    top: -10px;
    right: -8px;
    z-index: 2;
    padding: 4px 10px;
    background: linear-gradient(135deg, #fde047, #f59e0b);
    color: #1a1a1a;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 999px;
    box-shadow: 0 0 18px rgba(253, 224, 71, 0.6);
    transform: rotate(6deg);
  }

  .cabinet-top {
    margin-bottom: 8px;
  }

  .cabinet-marquee {
    background: linear-gradient(180deg, var(--cabinet-color) 0%, color-mix(in srgb, var(--cabinet-color) 70%, black) 100%);
    padding: 8px 12px;
    border-radius: 8px 8px 4px 4px;
    text-align: center;
    box-shadow:
      0 4px 15px var(--cabinet-glow),
      inset 0 -2px 4px rgba(0, 0, 0, 0.3),
      inset 0 2px 4px rgba(255, 255, 255, 0.2);
  }

  .marquee-text {
    font-family: 'Press Start 2P', var(--font-mono), monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    color: white;
    text-shadow:
      0 0 10px rgba(255, 255, 255, 0.8),
      2px 2px 0 rgba(0, 0, 0, 0.5);
    letter-spacing: 1px;
  }

  .cabinet-screen {
    padding: 8px;
    background: #0a0a0a;
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .screen-bezel {
    padding: 4px;
    background: linear-gradient(135deg, #333 0%, #1a1a1a 100%);
    border-radius: 4px;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.5);
  }

  .screen-content {
    position: relative;
    background: radial-gradient(circle at center, #001428 0%, #000 70%);
    padding: 20px 15px;
    border-radius: 2px;
    min-height: 120px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    transition: background 0.3s ease;
  }

  .screen-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
    pointer-events: none;
    z-index: 10;
  }

  .screen-icon {
    font-size: 2.5rem;
    margin-bottom: 8px;
    filter: drop-shadow(0 0 10px var(--cabinet-color));
    transition: transform 0.3s ease;
  }

  .screen-text {
    text-align: center;
  }

  .best-score {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--cabinet-color);
    text-shadow: 0 0 5px var(--cabinet-color);
    margin-bottom: 4px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .blink {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #fff;
    text-shadow: 0 0 10px #fff;
    letter-spacing: 1px;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  .cabinet-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 12px;
    background: linear-gradient(180deg, #222 0%, #1a1a1a 100%);
    border-radius: 4px;
    margin-bottom: 8px;
  }

  .joystick {
    width: 24px;
    height: 24px;
    background: radial-gradient(circle at 30% 30%, #444, #111);
    border-radius: 50%;
    box-shadow:
      0 4px 8px rgba(0, 0, 0, 0.5),
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      inset 0 2px 4px rgba(255, 255, 255, 0.1);
    position: relative;
  }

  .joystick::after {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 20px;
    background: linear-gradient(180deg, #333, #111);
    border-radius: 6px 6px 4px 4px;
    box-shadow:
      inset 0 -2px 4px rgba(0, 0, 0, 0.5),
      inset 0 2px 4px rgba(255, 255, 255, 0.1);
  }

  .buttons {
    display: flex;
    gap: 8px;
  }

  .btn-arcade {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    box-shadow:
      0 3px 6px rgba(0, 0, 0, 0.4),
      inset 0 -2px 4px rgba(0, 0, 0, 0.3),
      inset 0 2px 4px rgba(255, 255, 255, 0.2);
  }

  .btn-a {
    background: radial-gradient(circle at 30% 30%, #ff6b6b, #cc0000);
  }

  .btn-b {
    background: radial-gradient(circle at 30% 30%, #4ecdc4, #00a099);
  }

  .cabinet-base {
    text-align: center;
    padding: 8px 4px 4px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    justify-content: space-between;
  }

  .game-desc {
    font-size: 0.75rem;
    color: #a9b4c6;
    margin: 0;
    line-height: 1.4;
  }

  .cabinet-chips {
    display: flex;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 3px 8px;
    border-radius: 999px;
    border: 1px solid;
  }

  .chip-genre {
    color: var(--cabinet-color);
    border-color: color-mix(in srgb, var(--cabinet-color) 55%, transparent);
    background: color-mix(in srgb, var(--cabinet-color) 12%, transparent);
  }

  .chip-players {
    color: #999;
    border-color: #3a3a3a;
    background: rgba(255, 255, 255, 0.03);
  }

  @media (max-width: 600px) {
    .arcade-cabinet {
      width: 180px;
      padding: 8px;
    }

    .marquee-text {
      font-size: 0.55rem;
    }

    .screen-content {
      min-height: 100px;
      padding: 15px 10px;
    }

    .screen-icon {
      font-size: 2rem;
    }
  }
</style>
