---
import { useTranslations, getLocalizedPath } from '../i18n/translations';

interface Props {
  lang: 'en' | 'es' | 'cat';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container hero-content">
    <p class="kicker hero-kicker">{t('hero.name')} · {t('hero.tagline')}</p>
    <h1 class="hero-headline">
      {t('hero.headline1')}<span class="hero-accent">{t('hero.headlineAccent')}</span>{t('hero.headline2')}
      <span class="hero-aside">{t('hero.headlineAside')}</span>
    </h1>
    <p class="hero-description">{t('hero.description')}</p>
    <div class="hero-actions">
      <a href={getLocalizedPath('/projects', lang)} class="btn btn-primary">
        {t('nav.projects')} →
      </a>
      <a href={getLocalizedPath('/connect', lang)} class="btn btn-outline">
        {t('cta.connect')}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-3xl) 0;
    border-bottom: 1px solid var(--color-border);
    background:
      repeating-linear-gradient(
        -45deg,
        transparent 0 34px,
        color-mix(in srgb, var(--color-frame) 3%, transparent) 34px 35px
      );
  }

  .hero-kicker {
    margin-bottom: var(--space-lg);
  }

  .hero-headline {
    font-size: clamp(2.4rem, 6.5vw, 4.25rem);
    line-height: 1.08;
    font-weight: 600;
    max-width: 19ch;
    margin-bottom: var(--space-xl);
  }

  .hero-accent {
    display: inline-block;
    background: var(--color-accent-solid);
    color: #fff;
    border: var(--frame-width) solid var(--color-frame);
    border-radius: var(--radius);
    padding: 0 0.45rem;
    box-shadow: var(--shadow-btn);
    transform: rotate(-1deg);
  }

  .hero-aside {
    display: block;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
  }

  .hero-description {
    max-width: 600px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
</style>
